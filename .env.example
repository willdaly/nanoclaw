# Claude authentication (copy from ~/.claude/.credentials.json → claudeAiOauth.accessToken)
CLAUDE_CODE_OAUTH_TOKEN=

# Assistant name shown in chat
ASSISTANT_NAME=Andy

# WhatsApp: true if bot has its own dedicated phone number, false if sharing yours
ASSISTANT_HAS_OWN_NUMBER=false

# Web channel: public URL of this server (used in AgentFacts and NANDA registration)
# Use HTTPS in production.
PUBLIC_URL=https://your-domain.example

# NANDA registry base URL (script appends /register and status update route)
NANDA_REGISTRY_URL=http://registry.chat39.com:6900

# Agent identity for registration + fact card
NANDA_AGENT_ID=nanoclaw-main
NANDA_AGENT_HANDLE=@nanoclaw/main
NANDA_AGENT_NAME=NanoClaw Agent
NANDA_AGENT_DESCRIPTION=A container-isolated Claude assistant orchestrator.
NANDA_AGENT_VERSION=1.0.0

# Comma-separated values
NANDA_AGENT_CAPABILITIES=urn:nanda:cap:a2a-orchestration,urn:nanda:cap:nanda-registration
NANDA_AGENT_TAGS=assistant,orchestrator,nanoclaw

# Production safety: keep false unless you intentionally need temporary HTTP/local PUBLIC_URL.
ALLOW_INSECURE_PUBLIC_URL=false
